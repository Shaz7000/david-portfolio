{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] }
  },
  "include": ["app/**/*", "lib/**/*", "features/**/*", "realtime/**/*", "components/**/*", "providers/**/*", "hooks/**/*", "config/**/*", "middleware.js"]
}
